# StegoShield Backend Configuration
# 复制此文件为 .env 并修改相应配置

# Flask 配置
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# 安全配置
SECRET_KEY=your-secret-key-here-change-in-production

# 文件上传配置
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760

# 日志配置
LOG_LEVEL=INFO

# CORS 配置（生产环境应设置为具体的域名）
CORS_ORIGINS=*

# 环境模式
ENV=development
